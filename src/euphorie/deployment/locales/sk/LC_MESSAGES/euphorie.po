msgstr ""
"Ak bude táto možnosť naplánovať opatrenia zvolená, bude ponúknutá priamo na "
"stránke „Identifikácia.“ V navigácii nebude samostatný krok „Akčný plán“."

#. Default: "The default export escapes HTML, which is not supportedby
#. eTranslate"
#: euphorie/content/browser/export.py:169
msgid "description_is_etranslate_compatible"
msgstr ""

#. Default: "Defines how the “Measures in place” options are displayed to the
#. user. Choose “Simple” if the texts for Description and General Approach are
#. identical in your measures. Choose “Full” if the texts in General Approach
#. provide more details than the Description."
