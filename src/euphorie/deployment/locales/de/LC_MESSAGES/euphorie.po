#: euphorie/content/user.py:52
msgid "error_invalid_login"
msgstr "Ein Anmeldename darf nur Kleinbuchstaben und Zahlen enthalten."

#. Default: "Please upload a valid XML file"
#: euphorie/content/browser/upload.py:592
msgid "error_invalid_xml"
msgstr "Laden Sie eine gültige XML-Datei hoch."

#. Default: "Please enter your email address"
#: euphorie/client/browser/login.py:170
msgid "error_missing_email"
msgstr "Geben Sie Ihre E-Mail-Adresse ein."

#. Default: "Please enter a password"
#: euphorie/client/browser/login.py:178
