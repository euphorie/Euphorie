msgstr "Geben Sie ein Passwort ein."

#. Default: "Passwords do not match"
#: euphorie/client/browser/login.py:182
#: euphorie/client/browser/reset_password.py:256
msgid "error_password_mismatch"
msgstr "Die Passwörter stimmen nicht überein."

#. Default: "The password needs to be at least 12 characters long and needs to
#. contain at least one lower case letter, one upper case letter and one
#. digit."
#: euphorie/client/browser/login.py:155
msgid "error_password_policy_violation"
msgstr ""
"Das Passwort muss mindestens 12 Zeichen lang sein und mindestens einen "
