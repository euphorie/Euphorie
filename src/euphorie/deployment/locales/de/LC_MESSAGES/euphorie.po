#. Default: "An accout can only be created for you if you accept the terms and
#. conditions."
#: euphorie/client/browser/login.py:190
msgid "error_terms_not_accepted"
msgstr ""
"Ein Konto kann nur für Sie erstellt werden, wenn Sie die "
"Geschäftsbedingungen akzeptieren."

#. Default: "This date must be on or after the start date."
#: euphorie/client/browser/risk.py:84
msgid "error_validation_after_start_date"
msgstr "Dieses Datum muss nach dem Startdatum liegen."

#. Default: "This date must be on or before the end date."
#: euphorie/client/browser/risk.py:104
msgid "error_validation_before_end_date"
msgstr "Dieses Datum muss vor dem Enddatum liegen."

#. Default: "This value must be a valid date"
#: euphorie/client/browser/webhelpers.py:1297
msgid "error_validation_date"
msgstr "Dieser Wert muss ein gültiges Datum sein"

#. Default: "This value must be a valid date and time"
#: euphorie/client/browser/webhelpers.py:1301
msgid "error_validation_datetime"
msgstr "Dieser Wert muss ein gültiges Datum und eine gültige Uhrzeit sein"

#. Default: "This value must be a valid email address"
#: euphorie/client/browser/webhelpers.py:1308
msgid "error_validation_email"
msgstr "Dieser Wert muss eine gültige E-Mail-Adresse sein"

#. Default: "This value must be a number"
#: euphorie/client/browser/webhelpers.py:1315
