#: euphorie/client/browser/templates/login.pt:299
#: euphorie/client/browser/templates/shell.pt:135
msgid "home_link"
msgstr "Mælaborð"

#. Default: "Are the measures that are already implemented sufficient?"
#: euphorie/content/utils.py:145
msgid "implemented_measures_sufficient"
msgstr "Eru valdar úrbótaaðgerðir nægjanlegar til að hafa stjórn á áhættunni?"

#. Default: "Your login name and/or password were entered incorrectly. Please
#. check and try again or ${request_an_email_reminder}."
